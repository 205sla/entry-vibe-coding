{
  "name": "10번 클릭하면 순간이동",
  "variables": [
    {
      "id": "clicks",
      "name": "클릭수",
      "variableType": "variable",
      "value": "0",
      "visible": true,
      "x": -220, "y": 120
    }
  ],
  "objects": [
    {
      "id": "target",
      "name": "클릭 대상",
      "pictures": [
        {
          "id": "pic",
          "name": "대상",
          "fileurl": "/images/mascot/bot205-hello.svg",
          "imageType": "svg",
          "dimension": { "width": 200, "height": 240 }
        }
      ],
      "entity": { "x": 0, "y": 0 },
      "script": [
        [
          { "type": "when_object_click" },
          {
            "type": "change_variable",
            "params": [{ "__field": "clicks" }, 1, null]
          },
          {
            "type": "_if",
            "params": [
              {
                "type": "boolean_basic_operator",
                "params": [
                  { "type": "get_variable", "params": [{ "__field": "clicks" }, null] },
                  { "__field": "GREATER_OR_EQUAL" },
                  { "type": "number", "params": ["10"] }
                ]
              },
              null
            ],
            "statements": [[
              { "type": "set_variable", "params": [{ "__field": "clicks" }, 0, null] },
              {
                "type": "locate_xy",
                "params": [
                  {
                    "type": "calc_rand",
                    "params": [
                      null,
                      { "type": "number", "params": ["-200"] },
                      null,
                      { "type": "number", "params": ["200"] },
                      null
                    ]
                  },
                  {
                    "type": "calc_rand",
                    "params": [
                      null,
                      { "type": "number", "params": ["-110"] },
                      null,
                      { "type": "number", "params": ["110"] },
                      null
                    ]
                  },
                  null
                ]
              },
              {
                "type": "dialog_time",
                "params": [
                  { "type": "text", "params": ["순간이동!"] },
                  { "type": "number", "params": ["0.8"] },
                  { "__field": "speak" },
                  null
                ]
              }
            ]]
          }
        ]
      ]
    }
  ]
}
