# Node
node_modules/
npm-debug.log*

# 로컬 npm install 스크래치 — setup 스크립트로 재생성
vendor-install/

# Runtime
temp/
test-results/
playwright-report/

# Setup script cache (cloned fallbacks for external users without siblings)
.setup-cache/

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# ─── Third-party assets (재구축 가능) ──────────────────────────
# entryjs/dist 복사본 (17MB+)
public/lib/entry-js/dist/
# entryjs/extern 복사본
public/lib/entry-js/extern/
# entryjs/images 복사본 (32MB)
public/lib/entry-js/images/

# entryjs 기원의 public/images/ 전체 제외, 직접 만든 game/blank만 포함
public/images/**

# npm dist 복사본 (preloadjs 패치 포함)
public/lib/vendor/

# cursor 파일 (handclosed/handopen.cur)은 커밋 — 콜드 클론에서도 필요

# ─── External module junctions (링크 타겟 커밋 불가) ──────────
public/lib/entry-tool
public/lib/entry-paint
public/lib/entry-lms
public/lib/sound-editor
public/lib/legacy-video

# ─── 직접 만든 게임 에셋은 유지 ─────────────────────────────
!public/images/blank/
!public/images/blank/**
!public/images/game/
!public/images/game/**
# 205 mascot SVG — 픽스처 8개가 참조, 콜드 클론 재빌드에 필수
!public/images/mascot/
!public/images/mascot/**

# tools/*.mjs 런타임 검증 스크립트가 생성하는 artifact (inspect, verify-*)
tools/inspect-*.png
tools/verify-*.png

# verify / screenshot 도구의 단계별 캡처 디렉토리 (재생성 가능)
tests/output/
tests/fixtures/*-shots/
